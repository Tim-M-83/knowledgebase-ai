OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
LLM_PROVIDER=openai
EMBEDDINGS_PROVIDER=openai
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/knowledgebase
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-strong-secret
SECRETS_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
COOKIE_SECURE=false

FILE_STORAGE_PATH=/data/uploads
APP_LOG_DIR=/data/logs
APP_LOG_LEVEL=INFO
APP_LOG_MAX_BYTES=5242880
APP_LOG_BACKUP_COUNT=5
APP_LOG_EXPORT_WINDOW_HOURS=72
APP_LOG_EXPORT_MAX_LINES=10000
MAX_UPLOAD_MB=50

NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LICENSE_SERVER_BASE_URL=https://app.automateki.de
LICENSE_SERVER_ADMIN_TOKEN=
LICENSE_WORKSPACE_ID=
LICENSE_COMPANY_NAME=KnowledgeBase AI
LICENSE_BILLING_EMAIL=
LICENSE_ENFORCEMENT_ENABLED=true
LICENSE_VALIDATE_INTERVAL_HOURS=6
LICENSE_OFFLINE_GRACE_HOURS=24
LICENSE_REQUEST_TIMEOUT_SECONDS=10
